// First Screen — Pine strategy (mirrors first_screen.py W1/D1: MA轉上 + 股跌日量低)
// Chart: Daily recommended. Weekly logic via request.security("W").
// Entry: first bar W OR D turns on (not consecutive days). Flat only — no pyramiding.
// After stop loss: flat → wait for next FS first-day (pass must turn off then on again).
// Risk: 7% stop; after stop×RR profit (default 3R) trail weakDrawPct% from peak — no fixed TP.
//@version=5
strategy("First Screen Strategy", shorttitle="FS Strat", overlay=true, pyramiding=1,
     initial_capital=100000, currency=currency.USD, commission_type=strategy.commission.percent,
     commission_value=0.01, slippage=1,
     default_qty_type=strategy.fixed, default_qty_value=1,
     calc_on_every_tick=false, process_orders_on_close=true)

// ── Risk / exit (change in TV anytime) ───────────────────────────────────────
grpRisk = "Risk & exits"
riskPct       = input.float(1.0, "Risk per trade (% equity)", minval=0.1, step=0.1, group=grpRisk)
stopPct       = input.float(7.0, "Stop loss (%)", minval=0.5, step=0.5, group=grpRisk)
useFixedTP    = input.bool(false, "Use fixed TP at stop×RR (instead of weakness trail)", group=grpRisk)
rrRatio       = input.float(3.0, "R multiple before weakness trail (e.g. 3 = +21% if stop 7%)", minval=0.5, step=0.5, group=grpRisk)
useWeakExit   = input.bool(true, "Sell into weakness (trail from peak)", group=grpRisk)
weakDrawPct   = input.float(7.0, "Weakness trail from peak (%)", minval=0.5, step=0.5, group=grpRisk)
reAfterStop   = input.bool(true, "After stop loss, buy on next FS first-day", group=grpRisk)

// ── First Screen filters ─────────────────────────────────────────────────────
grpFS = "First Screen"
useW1         = input.bool(true, "Use W1 (weekly)", group=grpFS)
useD1         = input.bool(true, "Use D1 (daily)", group=grpFS)
volMaD        = input.int(50, "D1 Vol MA length", minval=5, group=grpFS)
volMaW        = input.int(50, "W1 Vol MA length", minval=5, group=grpFS)
downVolSlack  = input.float(5.0, "Down-day vol slack (% over VolMA)", minval=0, step=0.5, group=grpFS) / 100.0
dPassRatio    = input.float(0.55, "D1 down-day pass ratio", minval=0.1, maxval=1, step=0.05, group=grpFS)
dMinHits      = input.int(4, "D1 down-day min hits", minval=1, group=grpFS)
wPassRatio    = input.float(0.42, "W1 down-day pass ratio", minval=0.1, maxval=1, step=0.05, group=grpFS)
wMinHits      = input.int(2, "W1 down-day min hits", minval=1, group=grpFS)
flatSlopePct  = input.float(0.8, "10MA flat slope floor (% / 5 bars)", minval=0.1, step=0.1, group=grpFS) / 100.0
flatMinBars   = input.int(1, "MA flat min bars (turn-up)", minval=1, maxval=8, group=grpFS,
     tooltip="10MA 轉平要連續幾根 K（5-bar slope ≥ flat floor）。1=而家；3=要橫行 3 根")

grpVis = "Display"
showSignals   = input.bool(true, "Mark first-day entries", group=grpVis)
showPassBg    = input.bool(true, "Background when W|D pass", group=grpVis)

// ── Helpers ──────────────────────────────────────────────────────────────────
slope5(s, off) =>
    base = s[off + 5]
    base > 0 ? (s[off] - base) / base : 0.0

f_flat_run_ok(s10, anchor, minBars) =>
    if minBars <= 1
        true
    else
        ok = false
        for start = anchor to math.min(anchor + 8, bar_index)
            if start + minBars - 1 > bar_index
                continue
            run = true
            for j = 0 to minBars - 1
                if slope5(s10, start + j) < -flatSlopePct
                    run := false
            if run
                ok := true
                break
        ok

// MA inflection up (detect_ma_inflection_up + weekly relax)
f_ma_turn(bool isWeek) =>
    lookback = 35
    s10 = ta.sma(close, 10)
    s20 = ta.sma(close, 20)
    s50 = ta.sma(close, 50)
    e20 = ta.ema(close, 20)
    ok = false
    if bar_index >= lookback + 10
        // walk back from [0] to find 10MA trough start of recovery
        ti = 0
        for k = 0 to lookback - 1
            if s10[k] >= s10[k + 1] * 0.997
                ti := k + 1
            else
                break
        troughVal = s10[ti]
        refEnd = ti + 15
        priorPeak = troughVal
        for k = ti to math.min(refEnd, bar_index)
            if s10[k] > priorPeak
                priorPeak := s10[k]
        dropPct = priorPeak > 0 ? (priorPeak - troughVal) / priorPeak : 0.0
        hadPb = dropPct >= 0.03 or (ti >= 3 and s10[ti + 3] > s10[ti] * 1.003) or (ti >= 5 and s10[ti + 1] <= s10[ti + 5] * 1.008)
        recovered = s10[0] > troughVal * 1.01
        nowRise = isWeek ? (s10[0] > s10[2] and s10[0] > troughVal * 1.008) : (s10[0] > s10[2] and s10[2] >= s10[5] * 0.995)
        s20Floor = s20[1]
        for k = 2 to 8
            s20Floor := math.min(s20Floor, s20[k])
        s20Turn = s20[0] > s20[2] or s20[0] > s20Floor * 1.001
        above10 = close > s10[0]
        aboveE20 = close > e20[0]
        priceOk = above10 and (aboveE20 or close > s50[0] * 0.92)
        stacking = s10[0] >= s20[0] * 0.94 or (above10 and s10[0] > troughVal * 1.02)
        inWin = ti <= lookback
        flatOk = f_flat_run_ok(s10, ti, flatMinBars)
        ok := hadPb and recovered and nowRise and s20Turn and stacking and priceOk and inWin and flatOk
    ok

// 10MA flat window start (find_ma10_flat_start simplified)
f_flat_start(bool isWeek) =>
    localSpan = isWeek ? 10 : 18
    maxSpan = isWeek ? 20 : 45
    fallback = isWeek ? 12 : 20
    s10 = ta.sma(close, 10)
    flatOff = fallback
    if bar_index >= 25
        searchEnd = 2
        searchStart = math.min(localSpan, bar_index - 5)
        minOff = searchStart
        minV = s10[searchStart]
        for k = searchStart to searchEnd
            if s10[k] < minV
                minV := s10[k]
                minOff := k
        // recovery trough: walk from [0]
        tOff = 0
        for k = 0 to searchStart
            if s10[k] >= s10[k + 1] * 0.997
                tOff := k + 1
            else
                break
        minOff := tOff
        peakOff = minOff + 3
        peakV = s10[math.min(peakOff, bar_index)]
        for k = peakOff to math.min(minOff + 25, bar_index)
            if s10[k] > peakV
                peakV := s10[k]
        if peakV >= s10[minOff] * 1.03
            fStart = minOff
            found = false
            for k = minOff to 0
                if k + flatMinBars - 1 > bar_index
                    continue
                run = true
                for j = 0 to flatMinBars - 1
                    if slope5(s10, k + j) < -flatSlopePct
                        run := false
                if run
                    fStart := k
                    found := true
                    break
            if not found
                for k = minOff to 0
                    if slope5(s10, k) >= -flatSlopePct
                        fStart := k
                        break
            winLen = fStart + 1
            if winLen > maxSpan
                fStart := maxSpan - 1
            flatOff := fStart
    flatOff

// down_vol (assess_volume_up_down — down side only for First Screen filter)
f_down_vol(bool isWeek) =>
    volMaLen = isWeek ? volMaW : volMaD
    passRatio = isWeek ? wPassRatio : dPassRatio
    minHits = isWeek ? wMinHits : dMinHits
    s10 = ta.sma(close, 10)
    vma = ta.sma(volume, volMaLen)
    cap = 1.0 + downVolSlack
    ok = false
    if bar_index >= volMaLen + 5
        seg = f_flat_start(isWeek)
        dHit = 0
        dTot = 0
        dVolSum = 0.0
        dVmaSum = 0.0
        uTot = 0
        for i = 0 to seg
            k = seg - i
            if k + 1 > bar_index
                continue
            v = vma[k]
            if v <= 0
                continue
            prevC = close[k + 1]
            if close[k] < prevC
                dTot += 1
                dVolSum += volume[k]
                dVmaSum += v
                if volume[k] < v * cap
                    dHit += 1
            else if close[k] > prevC
                uTot += 1
        // no down days after flat → pass (V-bottom launch)
        if dTot == 0 and uTot > 0
            ok := true
        else if dTot > 0
            need = math.max(math.min(minHits, dTot), math.ceil(dTot * passRatio))
            perBar = dHit >= need
            avgOk = dVolSum / dTot < (dVmaSum / dTot) * cap
            ok := perBar and avgOk
    ok

f_fs_pass(bool isWeek) =>
    f_ma_turn(isWeek) and f_down_vol(isWeek)

// D1 on chart TF; W1 from weekly
dPass = useD1 ? f_fs_pass(false) : false
wPassRaw = f_fs_pass(true)
wPass = useW1 ? request.security(syminfo.tickerid, "W", wPassRaw, gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off) : false

fsPass = dPass or wPass
firstDay = fsPass and not fsPass[1]

// ── Re-entry after stop (flat → next FS rising edge) ─────────────────────────
var int closedSeen = 0
var bool awaitNextFs = false
if strategy.closedtrades > closedSeen
    lastIdx = strategy.closedtrades - 1
    if reAfterStop and strategy.closedtrades.profit(lastIdx) < 0
        awaitNextFs := true
    closedSeen := strategy.closedtrades

// Must be flat; after stop, next firstDay (FS pass off → on) triggers re-entry
flatOk = strategy.position_size == 0
buySignal = firstDay and flatOk
if buySignal and awaitNextFs
    awaitNextFs := false

// ── Position sizing: risk % of equity / stop distance ──────────────────────
stopDist = close * stopPct / 100.0
riskCash = strategy.equity * riskPct / 100.0
qty = stopDist > 0 ? math.max(1, math.floor(riskCash / stopDist)) : 1

// ── Entries (each signal = independent trade id) ─────────────────────────────
var int tradeSeq = 0
if buySignal and strategy.equity > 0
    tradeSeq += 1
    eid = "FS" + str.tostring(tradeSeq)
    strategy.entry(eid, strategy.long, qty=qty, comment="FS " + (dPass and wPass ? "W+D" : dPass ? "D" : "W"))
    ep = close
    stopPx = ep * (1.0 - stopPct / 100.0)
    tpPx = ep * (1.0 + stopPct * rrRatio / 100.0)
    trailTicks = math.max(1, int(math.round(ep * weakDrawPct / 100.0 / syminfo.mintick)))
    // Trail only activates after stopPct × rrRatio profit (e.g. 7% × 3 = +21%)
    trailActivateTicks = math.max(1, int(math.round(ep * stopPct * rrRatio / 100.0 / syminfo.mintick)))
    xid = "X" + str.tostring(tradeSeq)
    if useFixedTP
        strategy.exit(xid, eid, stop=stopPx, limit=tpPx)
    else if useWeakExit
        // −stop% hard stop until +3R; then trail weakDrawPct% below peak (sell into weakness)
        strategy.exit(xid, eid, stop=stopPx, trail_points=trailTicks, trail_offset=trailActivateTicks)
    else
        strategy.exit(xid, eid, stop=stopPx)

// ── Visuals ──────────────────────────────────────────────────────────────────
bgcolor(showPassBg and fsPass ? color.new(color.teal, 92) : na)
plotshape(showSignals and buySignal, title="FS 1st day", style=shape.triangleup, location=location.belowbar,
     color=color.new(color.lime, 0), size=size.small, text="FS")

var table t = table.new(position.top_right, 2, 5, bgcolor=color.new(color.black, 80))
if barstate.islast
    table.cell(t, 0, 0, "D1", text_color=color.white)
    table.cell(t, 1, 0, dPass ? "✓" : "—", text_color=dPass ? color.lime : color.gray)
    table.cell(t, 0, 1, "W1", text_color=color.white)
    table.cell(t, 1, 1, wPass ? "✓" : "—", text_color=wPass ? color.lime : color.gray)
    table.cell(t, 0, 2, "FS", text_color=color.white)
    table.cell(t, 1, 2, fsPass ? "ON" : "off", text_color=fsPass ? color.lime : color.gray)
    table.cell(t, 0, 3, "1st?", text_color=color.white)
    table.cell(t, 1, 3, firstDay ? "edge" : "—", text_color=firstDay ? color.yellow : color.gray)
    table.cell(t, 0, 4, "Buy?", text_color=color.white)
    table.cell(t, 1, 4, buySignal ? "YES" : (awaitNextFs ? "wait FS" : "—"),
         text_color=buySignal ? color.lime : (awaitNextFs ? color.orange : color.gray))
